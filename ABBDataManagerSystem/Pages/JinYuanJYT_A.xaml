<UserControl xmlns:Views="clr-namespace:ABBDataManagerSystem.Pages.Views"  x:Class="ABBDataManagerSystem.Pages.JinYuanJYT_A"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:ABBDataManagerSystem.Pages"
             xmlns:hc="https://handyorg.github.io/handycontrol"
             mc:Ignorable="d" Background="White" Loaded="UserControl_Loaded" Unloaded="UserControl_Unloaded" d:DesignHeight="1111" d:DesignWidth="1411">
    <UserControl.Resources>
        <Style TargetType="TextBlock" BasedOn="{StaticResource {x:Type TextBlock}}">
            <Setter Property="FontSize" Value="18"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
        </Style>
        <Style TargetType="Button" BasedOn="{StaticResource {x:Type Button}}">
            <Setter Property="FontSize" Value="18"/>
            <Setter Property="Width" Value="120"/>
            <Setter Property="Height" Value="40"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
        </Style>
        <Style TargetType="CheckBox" BasedOn="{StaticResource {x:Type CheckBox}}">
            <Setter Property="FontSize" Value="18"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
        </Style>
        <Style TargetType="ComboBox" BasedOn="{StaticResource {x:Type ComboBox}}">
            <Setter Property="FontSize" Value="18"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
        </Style>
    </UserControl.Resources>
    <Grid Margin="30,20,30,20">
        <Grid.ColumnDefinitions>

        </Grid.ColumnDefinitions>
        <Grid.RowDefinitions>
            <RowDefinition Height="60"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="1*"/>
            <RowDefinition Height="60"/>
        </Grid.RowDefinitions>
        <StackPanel Grid.Row="0">
            <TextBlock HorizontalAlignment="Left" Margin="0,10" TextAlignment="Center" TextWrapping="Wrap" Text="金源JYT-A变比测量仪" FontSize="24" FontWeight="Bold"/>
        </StackPanel>
        <StackPanel Orientation="Horizontal" Grid.Row="1" Margin="0, 10">
            <TextBlock Text="连接" Margin="0, 0, 10, 0" FontWeight="Bold"/>
            <ToggleButton IsChecked="{Binding ContextMenuIsShow}" Style="{StaticResource ToggleButtonSwitch}"  Margin="0, 0, 20, 0" Name="swConnect" Checked="swConnect_CheckedChange" Unchecked="swConnect_CheckedChange">
                <ToggleButton.Background>
                    <SolidColorBrush Color="{DynamicResource SecondaryTextColor}"/>
                </ToggleButton.Background>
            </ToggleButton>
            <StackPanel HorizontalAlignment="Left" Orientation="Horizontal" VerticalAlignment="Top">
                <TextBlock TextWrapping="Wrap" Text="串口" VerticalAlignment="Center" Width="40" Margin="0,0,10,0"/>
                <ComboBox Width="120" Name="cbSerialPort"/>
            </StackPanel>
            <StackPanel HorizontalAlignment="Left" Orientation="Horizontal" VerticalAlignment="Top">
                <TextBlock Width="60" Text="波特率" VerticalAlignment="Center" Margin="20, 0, 10, 0"/>
                <ComboBox Width="120"  VerticalAlignment="Center" Name="cbBoundRate" SelectedIndex="1">
                    <ComboBoxItem Content="4800"/>
                    <ComboBoxItem Content="9600"/>
                    <ComboBoxItem Content="12800"/>
                </ComboBox>
            </StackPanel>

            <!--<StackPanel HorizontalAlignment="Left" Orientation="Horizontal" VerticalAlignment="Top" Margin="10,0">
                <CheckBox Content="高压侧" VerticalAlignment="Center" Name="cbCH1"/>
                <Viewbox Width="10"/>
                <ComboBox Width="100" Name="cbHVCurrents"/>
                <Viewbox Width="10"/>
                <CheckBox Content="低压侧" VerticalAlignment="Center" Name="cbCH2"/>
                <Viewbox Width="10"/>
                <ComboBox Width="100" Name="cbLVCurrents"/>
            </StackPanel>-->
        </StackPanel>
        <StackPanel Grid.Row="2" Orientation="Horizontal" Margin="0,10">
            <TextBlock Width="80" Text="测试类型" VerticalAlignment="Center" Margin="0, 0, 10, 0"/>
            <ComboBox Name="cbTestMode" Width="120" SelectedIndex="0" SelectionChanged="cbTestMode_SelectionChanged">
                <ComboBoxItem Content="三相测试"/>
                <ComboBoxItem Content="单相测试"/>
            </ComboBox>
            <TextBlock Width="80" Text="试验电压" VerticalAlignment="Center" Margin="20, 0, 10, 0"/>
            <ComboBox Name="cbVoltageConfig" Width="120" SelectedIndex="0">
            </ComboBox>
            <TextBlock Width="120" Text="高压电压(kV)" VerticalAlignment="Center" Margin="20, 0, 10, 0"/>
            <hc:NumericUpDown Width="120" Name="tbHighVoltage" Value="1.0" ValueFormat="N2" FontSize="18"/>
            <TextBlock Width="120" Text="低压电压(kV)" VerticalAlignment="Center" Margin="20, 0, 10, 0"/>
            <hc:NumericUpDown Width="120" Name="tbLowVoltage" Value="1.0" ValueFormat="N2" FontSize="18"/>
        </StackPanel>
        <StackPanel Grid.Row="3" Orientation="Horizontal" Margin="0, 10">
            <TextBlock Width="80" Text="分接位置" VerticalAlignment="Center" Margin="0, 0, 10, 0"/>
            <ComboBox Name="cbTappingPoint" Width="120" SelectedIndex="0">
            </ComboBox>
            <TextBlock Width="80" Text="额定分接" VerticalAlignment="Center" Margin="20, 0, 10, 0"/>
            <hc:NumericUpDown Width="120" Name="tbRatedConnection" Value="3" FontSize="18" Minimum="0"/>
            <TextBlock Width="120" Text="正分接数" VerticalAlignment="Center" Margin="20, 0, 10, 0"/>
            <hc:NumericUpDown Width="120" Name="tbPositiveConnection" Value="5" FontSize="18" Minimum="0"/>
            <TextBlock Width="120" Text="分接间距(%)" VerticalAlignment="Center" Margin="20, 0, 10, 0"/>
            <hc:NumericUpDown Width="120" Name="tbConnectionGap" Value="5" FontSize="18" Minimum="0" ValueFormat="N1" />
        </StackPanel>
        <StackPanel Grid.Row="4" Orientation="Horizontal" Margin="0, 10">
            <TextBlock Width="140" Text="同极性显示(单相)" VerticalAlignment="Center" Margin="0, 0, 10, 0"/>
            <ComboBox Name="cbHomopolarityDisplay" Width="120" SelectedIndex="0">
            </ComboBox>
            <TextBlock Width="80" Text="联结方式" VerticalAlignment="Center" Margin="20, 0, 10, 0"/>
            <ComboBox Name="cbHighVoltageConnection" Width="80" SelectedIndex="0">
            </ComboBox>
            <TextBlock Text="-" Margin="5, 0"/>
            <ComboBox Name="cbLowVoltageConnection" Width="80" SelectedIndex="0">
            </ComboBox>
            <TextBlock Text="-" Margin="5, 0"/>
            <hc:NumericUpDown Width="120" Name="tbGroup" Value="0" FontSize="18" Minimum="0" Maximum="11"/>
        </StackPanel>
        <Grid Grid.Row="5" Margin="0,20,0,10" >
            <Grid.ColumnDefinitions>
                <ColumnDefinition/>
                <ColumnDefinition/>
            </Grid.ColumnDefinitions>
            <TabControl SelectionChanged="TabControl_SelectionChanged" Grid.Column="0">
                <TabItem Header="单相测试" FontSize="18" Height="40" Name="tiSinglePhase">
                    <ScrollViewer HorizontalScrollBarVisibility="Visible" VerticalScrollBarVisibility="Visible" Style="{StaticResource ScrollViewerNativeBaseStyle}">
                        <Grid Margin="40" MinHeight="300" MinWidth="600">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition/>
                                <ColumnDefinition/>
                                <ColumnDefinition/>
                            </Grid.ColumnDefinitions>
                            <Grid.RowDefinitions>
                                <RowDefinition/>
                                <RowDefinition/>
                                <RowDefinition/>
                                <RowDefinition/>
                            </Grid.RowDefinitions>
                            <Grid Grid.Row="0" Grid.Column="0">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="60"/>
                                    <ColumnDefinition Width="1*"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Text="变比" Grid.Column="0" Margin="10, 0"/>
                                <TextBox Height="40" Grid.Column="1" IsReadOnly="True"/>
                            </Grid>

                            <Grid Grid.Row="0" Grid.Column="1">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="60"/>
                                    <ColumnDefinition Width="1*"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Text="误差" Grid.Column="0" Margin="10, 0"/>
                                <TextBox Height="40" Grid.Column="1" IsReadOnly="True"/>
                            </Grid>

                            <Grid Grid.Row="1" Grid.Column="0">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="60"/>
                                    <ColumnDefinition Width="1*"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Text="电压" Grid.Column="0" Margin="10, 0"/>
                                <TextBox Height="40" Grid.Column="1" IsReadOnly="True"/>
                            </Grid>

                            <Grid Grid.Row="1" Grid.Column="1">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="60"/>
                                    <ColumnDefinition Width="1*"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Text="电流" Grid.Column="0" Margin="10, 0"/>
                                <TextBox Height="40" Grid.Column="1" IsReadOnly="True"/>
                            </Grid>

                            <Grid Grid.Row="1" Grid.Column="2">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="60"/>
                                    <ColumnDefinition Width="1*"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Text="频率" Grid.Column="0" Margin="10, 0"/>
                                <TextBox Height="40" Grid.Column="1" IsReadOnly="True"/>
                            </Grid>

                            <Grid Grid.Row="2" Grid.Column="0">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="100"/>
                                    <ColumnDefinition Width="1*"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Text="分接位" Grid.Column="0" Margin="10, 0"/>
                                <TextBox Height="40" Grid.Column="1" IsReadOnly="True"/>
                            </Grid>

                            <Grid Grid.Row="2" Grid.Column="1">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="60"/>
                                    <ColumnDefinition Width="1*"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Text="极性" Grid.Column="0" Margin="10, 0"/>
                                <TextBox Height="40" Grid.Column="1" IsReadOnly="True"/>
                            </Grid>

                            <Grid Grid.Row="3" Grid.Column="0">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="100"/>
                                    <ColumnDefinition Width="1*"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Text="计算变比" Grid.Column="0" Margin="10, 0"/>
                                <TextBox Height="40" Grid.Column="1" IsReadOnly="True"/>
                            </Grid>
                        </Grid>
                    </ScrollViewer>
                </TabItem>
                <TabItem Header="三相测试" FontSize="18" Height="40" Name="tiThreePhase">
                    <ScrollViewer HorizontalScrollBarVisibility="Visible" VerticalScrollBarVisibility="Visible" Style="{StaticResource ScrollViewerNativeBaseStyle}">
                        <Grid Margin="40" MinHeight="360" MinWidth="600">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="0.5*"/>
                                <ColumnDefinition Width="1*"/>
                                <ColumnDefinition Width="1*"/>
                                <ColumnDefinition Width="1*"/>
                            </Grid.ColumnDefinitions>
                            <Grid.RowDefinitions>
                                <RowDefinition/>
                                <RowDefinition/>
                                <RowDefinition/>
                                <RowDefinition/>
                                <RowDefinition/>
                                <RowDefinition/>
                                <RowDefinition/>
                                <RowDefinition/>
                            </Grid.RowDefinitions>
                            <TextBlock Text="A" FontSize="18" Grid.Column="1" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            <TextBlock Text="B" FontSize="18" Grid.Column="2" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            <TextBlock Text="C" FontSize="18" Grid.Column="3" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            <TextBlock Text="变比 " FontSize="20" Grid.Column="0" Grid.Row="1" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            <TextBlock Text="匝比 " FontSize="20" Grid.Column="0" Grid.Row="2" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            <TextBlock Text="误差 " FontSize="20" Grid.Column="0" Grid.Row="3" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            <TextBlock Text="电压 " FontSize="20" Grid.Column="0" Grid.Row="4" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            <TextBlock Text="电流 " FontSize="20" Grid.Column="0" Grid.Row="5" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            <TextBlock Text="联结方式 " FontSize="20" Grid.Column="0" Grid.Row="6" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            <TextBlock Text="计算变比 " FontSize="20" Grid.Column="0" Grid.Row="7" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            <TextBlock Text="频率 " FontSize="20" Grid.Column="2" Grid.Row="6" HorizontalAlignment="Right" VerticalAlignment="Center"/>
                            <TextBlock Text="分接位" FontSize="20" Grid.Column="2" Grid.Row="7" HorizontalAlignment="Right" VerticalAlignment="Center"/>
                            <TextBox FontSize="20" Grid.Column="1" Grid.Row="1" Height="40" Margin="10, 0" IsReadOnly="True"/>
                            <TextBox FontSize="20" Grid.Column="1" Grid.Row="2" Height="40" Margin="10, 0" IsReadOnly="True"/>
                            <TextBox FontSize="20" Grid.Column="1" Grid.Row="3" Height="40" Margin="10, 0" IsReadOnly="True"/>
                            <TextBox FontSize="20" Grid.Column="1" Grid.Row="4" Height="40" Margin="10, 0" IsReadOnly="True"/>
                            <TextBox FontSize="20" Grid.Column="1" Grid.Row="5" Height="40" Margin="10, 0" IsReadOnly="True"/>
                            <TextBox FontSize="20" Grid.Column="1" Grid.Row="6" Height="40" Margin="10, 0" IsReadOnly="True"/>
                            <TextBox FontSize="20" Grid.Column="1" Grid.Row="7" Height="40" Margin="10, 0" IsReadOnly="True"/>
                            <TextBox FontSize="20" Grid.Column="2" Grid.Row="1" Height="40" Margin="10, 0" IsReadOnly="True"/>
                            <TextBox FontSize="20" Grid.Column="2" Grid.Row="2" Height="40" Margin="10, 0" IsReadOnly="True"/>
                            <TextBox FontSize="20" Grid.Column="2" Grid.Row="3" Height="40" Margin="10, 0" IsReadOnly="True"/>
                            <TextBox FontSize="20" Grid.Column="2" Grid.Row="4" Height="40" Margin="10, 0" IsReadOnly="True"/>
                            <TextBox FontSize="20" Grid.Column="2" Grid.Row="5" Height="40" Margin="10, 0" IsReadOnly="True"/>
                            <TextBox FontSize="20" Grid.Column="3" Grid.Row="1" Height="40" Margin="10, 0" IsReadOnly="True"/>
                            <TextBox FontSize="20" Grid.Column="3" Grid.Row="2" Height="40" Margin="10, 0" IsReadOnly="True"/>
                            <TextBox FontSize="20" Grid.Column="3" Grid.Row="3" Height="40" Margin="10, 0" IsReadOnly="True"/>
                            <TextBox FontSize="20" Grid.Column="3" Grid.Row="4" Height="40" Margin="10, 0" IsReadOnly="True"/>
                            <TextBox FontSize="20" Grid.Column="3" Grid.Row="5" Height="40" Margin="10, 0" IsReadOnly="True"/>
                            <TextBox FontSize="20" Grid.Column="3" Grid.Row="6" Height="40" Margin="10, 0" IsReadOnly="True"/>
                            <TextBox FontSize="20" Grid.Column="3" Grid.Row="7" Height="40" Margin="10, 0" IsReadOnly="True"/>
                        </Grid>
                    </ScrollViewer>
                </TabItem>
            </TabControl>

            <Grid Grid.Column="1" Margin="10" Width="600" Height="680" HorizontalAlignment="Left" VerticalAlignment="Top">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <Grid.RowDefinitions>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="1.2*"/>
                </Grid.RowDefinitions>
                <TextBlock Margin="10, 0, 0, 0" Text="高压（串联）对低压（1）：" Grid.ColumnSpan="6"/>
                <TextBlock Text="分接位置" Grid.Row="1" Grid.RowSpan="2" HorizontalAlignment="Center"/>
                <TextBlock Text="分接电压（kv）" Grid.Row="1" Grid.Column="1" Grid.RowSpan="2" HorizontalAlignment="Center" TextWrapping="Wrap"/>
                <TextBlock Text="计算比值" Grid.Row="1" Grid.Column="2" Grid.RowSpan="2" HorizontalAlignment="Center" TextWrapping="Wrap"/>
                <TextBlock Text="实测变比误差（%）" Grid.Row="1" Grid.Column="3" Grid.ColumnSpan="3" HorizontalAlignment="Center" TextWrapping="Wrap"/>
                <TextBlock Text="AB/ab" Grid.Row="2" Grid.Column="3" HorizontalAlignment="Center"/>
                <TextBlock Text="BC/bc" Grid.Row="2" Grid.Column="4" HorizontalAlignment="Center"/>
                <TextBlock Text="CA/ca" Grid.Row="2" Grid.Column="5" HorizontalAlignment="Center"/>
                <!--<TextBlock Text="1"  Grid.Row="3" Grid.Column="0" HorizontalAlignment="Center"/>
                <TextBox Grid.Row="3" Grid.Column="1" HorizontalAlignment="Center" MinWidth="80" Height="40" IsReadOnly="True"/>
                <TextBox Grid.Row="3" Grid.Column="2" HorizontalAlignment="Center" MinWidth="80" Height="40" IsReadOnly="True"/>
                <TextBox Grid.Row="3" Grid.Column="3" HorizontalAlignment="Center" MinWidth="80" Height="40" IsReadOnly="True"/>
                <TextBox Grid.Row="3" Grid.Column="4" HorizontalAlignment="Center" MinWidth="80" Height="40" IsReadOnly="True"/>
                <TextBox Grid.Row="3" Grid.Column="5" HorizontalAlignment="Center" MinWidth="80" Height="40" IsReadOnly="True"/>

                <TextBlock Text="2"  Grid.Row="4" Grid.Column="0" HorizontalAlignment="Center"/>
                <TextBox Grid.Row="4" Grid.Column="1" HorizontalAlignment="Center" MinWidth="80" Height="40" IsReadOnly="True"/>
                <TextBox Grid.Row="4" Grid.Column="2" HorizontalAlignment="Center" MinWidth="80" Height="40" IsReadOnly="True"/>
                <TextBox Grid.Row="4" Grid.Column="3" HorizontalAlignment="Center" MinWidth="80" Height="40" IsReadOnly="True"/>
                <TextBox Grid.Row="4" Grid.Column="4" HorizontalAlignment="Center" MinWidth="80" Height="40" IsReadOnly="True"/>
                <TextBox Grid.Row="4" Grid.Column="5" HorizontalAlignment="Center" MinWidth="80" Height="40" IsReadOnly="True"/>

                <TextBlock Text="3"  Grid.Row="5" Grid.Column="0" HorizontalAlignment="Center"/>
                <TextBox Grid.Row="5" Grid.Column="1" HorizontalAlignment="Center" MinWidth="80" Height="40" IsReadOnly="True"/>
                <TextBox Grid.Row="5" Grid.Column="2" HorizontalAlignment="Center" MinWidth="80" Height="40" IsReadOnly="True"/>
                <TextBox Grid.Row="5" Grid.Column="3" HorizontalAlignment="Center" MinWidth="80" Height="40" IsReadOnly="True"/>
                <TextBox Grid.Row="5" Grid.Column="4" HorizontalAlignment="Center" MinWidth="80" Height="40" IsReadOnly="True"/>
                <TextBox Grid.Row="5" Grid.Column="5" HorizontalAlignment="Center" MinWidth="80" Height="40" IsReadOnly="True"/>

                <TextBlock Text="3"  Grid.Row="5" Grid.Column="0" HorizontalAlignment="Center"/>
                <TextBox Grid.Row="5" Grid.Column="1" HorizontalAlignment="Center" MinWidth="80" Height="40" IsReadOnly="True"/>
                <TextBox Grid.Row="5" Grid.Column="2" HorizontalAlignment="Center" MinWidth="80" Height="40" IsReadOnly="True"/>
                <TextBox Grid.Row="5" Grid.Column="3" HorizontalAlignment="Center" MinWidth="80" Height="40" IsReadOnly="True"/>
                <TextBox Grid.Row="5" Grid.Column="4" HorizontalAlignment="Center" MinWidth="80" Height="40" IsReadOnly="True"/>
                <TextBox Grid.Row="5" Grid.Column="5" HorizontalAlignment="Center" MinWidth="80" Height="40" IsReadOnly="True"/>

                <TextBlock Text="4"  Grid.Row="6" Grid.Column="0" HorizontalAlignment="Center"/>
                <TextBox Grid.Row="6" Grid.Column="1" HorizontalAlignment="Center" MinWidth="80" Height="40" IsReadOnly="True"/>
                <TextBox Grid.Row="6" Grid.Column="2" HorizontalAlignment="Center" MinWidth="80" Height="40" IsReadOnly="True"/>
                <TextBox Grid.Row="6" Grid.Column="3" HorizontalAlignment="Center" MinWidth="80" Height="40" IsReadOnly="True"/>
                <TextBox Grid.Row="6" Grid.Column="4" HorizontalAlignment="Center" MinWidth="80" Height="40" IsReadOnly="True"/>
                <TextBox Grid.Row="6" Grid.Column="5" HorizontalAlignment="Center" MinWidth="80" Height="40" IsReadOnly="True"/>

                <TextBlock Text="5"  Grid.Row="7" Grid.Column="0" HorizontalAlignment="Center"/>
                <TextBox Grid.Row="7" Grid.Column="1" HorizontalAlignment="Center" MinWidth="80" Height="40" IsReadOnly="True"/>
                <TextBox Grid.Row="7" Grid.Column="2" HorizontalAlignment="Center" MinWidth="80" Height="40" IsReadOnly="True"/>
                <TextBox Grid.Row="7" Grid.Column="3" HorizontalAlignment="Center" MinWidth="80" Height="40" IsReadOnly="True"/>
                <TextBox Grid.Row="7" Grid.Column="4" HorizontalAlignment="Center" MinWidth="80" Height="40" IsReadOnly="True"/>
                <TextBox Grid.Row="7" Grid.Column="5" HorizontalAlignment="Center" MinWidth="80" Height="40" IsReadOnly="True"/>-->

                <Views:TappingVoltageRatioFields x:Name="tvrTappingPoint1" Grid.Row="3" TappingIndex="1" Grid.ColumnSpan="6"/>
                <Views:TappingVoltageRatioFields x:Name="tvrTappingPoint2" Grid.Row="4" TappingIndex="2" Grid.ColumnSpan="6"/>
                <Views:TappingVoltageRatioFields x:Name="tvrTappingPoint3" Grid.Row="5" TappingIndex="3" Grid.ColumnSpan="6"/>
                <Views:TappingVoltageRatioFields x:Name="tvrTappingPoint4" Grid.Row="6" TappingIndex="4" Grid.ColumnSpan="6"/>
                <Views:TappingVoltageRatioFields x:Name="tvrTappingPoint5" Grid.Row="7" TappingIndex="5" Grid.ColumnSpan="6"/>
                <Views:TappingVoltageRatioFields x:Name="tvrTappingPoint6" Grid.Row="8" TappingIndex="6" Grid.ColumnSpan="6"/>
                <Views:TappingVoltageRatioFields x:Name="tvrTappingPoint7" Grid.Row="9" TappingIndex="7" Grid.ColumnSpan="6"/>
                <Views:TappingVoltageRatioFields x:Name="tvrTappingPoint8" Grid.Row="10" TappingIndex="8" Grid.ColumnSpan="6"/>
                <Views:TappingVoltageRatioFields x:Name="tvrTappingPoint9" Grid.Row="11" TappingIndex="9" Grid.ColumnSpan="6"/>

                <TextBlock Margin="10, 0, 0, 0" Text="高压（串联）对低压（1）：" Grid.Row="12" Grid.ColumnSpan="6"/>
                <Views:TappingVoltageRatioFields x:Name="tvrTappingPoint21" Grid.Row="13" TappingIndex="2-1" Grid.ColumnSpan="6"/>

                <Border Grid.Column="0" Grid.Row="0" BorderThickness="1.5,1.5,1.5,0" BorderBrush="Black" Grid.ColumnSpan="6"></Border>
                <Border Grid.Column="0" Grid.Row="1" BorderThickness="1.5,1.5,0,0" BorderBrush="Black" Grid.RowSpan="2"></Border>
                <Border Grid.Column="1" Grid.Row="1" BorderThickness="1.5,1.5,0,0" BorderBrush="Black" Grid.RowSpan="2"></Border>
                <Border Grid.Column="2" Grid.Row="1" BorderThickness="1.5,1.5,0,0" BorderBrush="Black" Grid.RowSpan="2"></Border>
                <Border Grid.Column="3" Grid.Row="1" BorderThickness="1.5,1.5,1.5,0" BorderBrush="Black" Grid.RowSpan="2" Grid.ColumnSpan="3"></Border>
                <Border Grid.Column="3" Grid.Row="1" BorderThickness="1.5" BorderBrush="Black" Grid.ColumnSpan="3"></Border>
                <Border Grid.Column="4" Grid.Row="2" BorderThickness="1.5,0,0,0" BorderBrush="Black" Grid.ColumnSpan="3"></Border>
                <Border Grid.Column="5" Grid.Row="2" BorderThickness="1.5,0,0,0" BorderBrush="Black" Grid.ColumnSpan="3"></Border>
                <Border Grid.Column="0" Grid.Row="12" BorderThickness="1.5,1.5,1.5,0" BorderBrush="Black" Grid.ColumnSpan="6"></Border>
                <Border Grid.Column="0" Grid.Row="13" BorderThickness="0,0,0,1.5" BorderBrush="Black" Grid.ColumnSpan="6"></Border>

                <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" VerticalAlignment="Center" Grid.Row="14" Grid.ColumnSpan="6" Margin="6">
                    <TextBlock Text="连接组1" Margin="0, 0, 10, 0"/>
                    <TextBox Width="120" Height="36" Margin="0, 0, 20, 0"/>
                    <TextBlock Text="连接组2" Margin="0, 0, 10, 0"/>
                    <TextBox Width="120" Height="36" Margin="0, 0, 20, 0"/>
                    <Button Width="60" Content="↓" Style="{StaticResource ButtonInfo}" Height="30" FontSize="18"/>
                </StackPanel>
            </Grid>
        </Grid>

        <StackPanel Orientation="Horizontal" Grid.Row="6">
            <Button Content="复位"     Style="{StaticResource ButtonInfo}"  Height="40" Width="120" FontSize="18"  Margin="0, 0, 10, 0"/>
            <Button Content="下发参数" Style="{StaticResource ButtonInfo}"  Height="40" Width="120" FontSize="18"  Margin="0, 0, 10, 0"/>
            <Button Content="测试"     Style="{StaticResource ButtonInfo}"  Height="40" Width="120" FontSize="18"  Margin="0, 0, 10, 0"/>
            <Button Content="重测"     Style="{StaticResource ButtonInfo}"  Height="40" Width="120" FontSize="18"  Margin="0, 0, 10, 0"/>
            <ScrollViewer HorizontalAlignment="Stretch" VerticalAlignment="Stretch" HorizontalScrollBarVisibility="Disabled" VerticalScrollBarVisibility="Auto">
                <TextBox IsReadOnly="True" Name="tbDebug" VerticalContentAlignment="Top" Width="400"/>
            </ScrollViewer>
        </StackPanel>
    </Grid>
</UserControl>
