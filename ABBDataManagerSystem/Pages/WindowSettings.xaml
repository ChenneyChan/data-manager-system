<Window x:Class="ABBDataManagerSystem.Pages.WindowSettings"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:ABBDataManagerSystem.Pages"
        xmlns:hc="https://handyorg.github.io/handycontrol"
        mc:Ignorable="d"
        Title="系统设置" Height="460" Width="652" WindowStartupLocation="CenterScreen" Loaded="Window_Loaded" Closing="Window_Closing" ResizeMode="NoResize">
    <Window.Resources>
        <Style x:Key="Label" TargetType="TextBlock" BasedOn="{StaticResource {x:Type TextBlock}}">
            <Setter Property="FontSize" Value="16" />
            <!--<Setter Property="FontWeight" Value="ExtraBold" />-->
            <Setter Property="TextAlignment" Value="Left"/>
            <Setter Property="HorizontalAlignment" Value="Right"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
            <Setter Property="Margin" Value="0,0,10,0"/>
        </Style>
        <Style TargetType="Button" BasedOn="{StaticResource {x:Type Button}}">
            <Setter Property="FontSize" Value="16"/>
            <!--<Setter Property="FontWeight" Value="ExtraBold" />-->
        </Style>
        <Style TargetType="TabItem" BasedOn="{StaticResource {x:Type TabItem}}">
            <Setter Property="FontSize" Value="16"/>
            <Setter Property="VerticalAlignment" Value="Center" />
        </Style>
        <Style TargetType="TextBox" BasedOn="{StaticResource {x:Type TextBox}}">
            <Setter Property="FontSize" Value="16"/>
            <Setter Property="VerticalAlignment" Value="Center" />
            <Setter Property="Height" Value="36"/>
        </Style>
    </Window.Resources>
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="*"/>
            <RowDefinition Height="80"/>
        </Grid.RowDefinitions>
        <TabControl>
            <TabItem Header ="数据库设置">
                <Grid Margin="20, 20, 20, 0">
                    <Grid.ColumnDefinitions>
                    </Grid.ColumnDefinitions>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="1*"/>
                        <RowDefinition Height="1*"/>
                        <RowDefinition Height="1*"/>
                        <RowDefinition Height="1*"/>
                        <RowDefinition Height="1*"/>
                    </Grid.RowDefinitions>
                    <StackPanel Grid.Row="0" Orientation="Horizontal" HorizontalAlignment="Center" VerticalAlignment="Center">
                        <TextBlock Text="数据库IP：" Width="120" Style="{StaticResource Label}" Margin="0,0,10,0"/>
                        <TextBox Name="tbDatabaseIp" Width="220"/>
                    </StackPanel>
                    <StackPanel Grid.Row="1" Orientation="Horizontal" HorizontalAlignment="Center" VerticalAlignment="Center">
                        <TextBlock Text="数据库端口：" Width="120" Style="{StaticResource Label}" Margin="0,0,10,0"/>
                        <TextBox Name="tbDatabasePort" Width="220"/>
                    </StackPanel>
                    <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Center" VerticalAlignment="Center">
                        <TextBlock Text="数据库名称：" Width="120" Style="{StaticResource Label}" Margin="0,0,10,0"/>
                        <TextBox Name="tbDatabaseName" Width="220"/>
                    </StackPanel>
                    <StackPanel Grid.Row="3" Orientation="Horizontal" HorizontalAlignment="Center" VerticalAlignment="Center">
                        <TextBlock Text="数据库账户：" Width="120" Style="{StaticResource Label}" Margin="0,0,10,0"/>
                        <TextBox Name="tbDatabaseUserName" Width="220"/>
                    </StackPanel>
                    <StackPanel Grid.Row="4" Orientation="Horizontal" HorizontalAlignment="Center" VerticalAlignment="Center">
                        <TextBlock Text="数据库密码：" Width="120" Style="{StaticResource Label}" Margin="0,0,10,0"/>
                        <hc:PasswordBox Name="tbDatabasePassword" Width="220" ShowEyeButton="True" FontSize="16" Height="36"/>
                    </StackPanel>
                    <Button Name="btPing" Style="{StaticResource ButtonPrimary}" Margin="420,0, 0, 0" Content="测试" Click="btPing_Click"/>
                    <Button Name="btDBTest" Style="{StaticResource ButtonPrimary}" Margin="420, 0, 0, 0" Content="测试" Click="btDBTest_Click" Grid.Row="1"/>
                </Grid>
            </TabItem>
            <TabItem Header="常规设置" IsSelected="True">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition/>
                        <RowDefinition/>
                        <RowDefinition/>
                        <RowDefinition/>
                        <RowDefinition/>
                    </Grid.RowDefinitions>
                    <StackPanel Grid.Row="0" Orientation="Horizontal" HorizontalAlignment="Center" VerticalAlignment="Center">
                        <TextBlock Text="工位选择：" Width="120" Style="{StaticResource Label}" Margin="0,0,10,0"/>
                        <ComboBox Name="cbWorkStation" Width="220">
                            <ComboBoxItem Content="工位一" IsSelected="True"/>
                            <ComboBoxItem Content="工位二"/>
                        </ComboBox>
                    </StackPanel>
                    <StackPanel Grid.Row="1" Orientation="Horizontal" HorizontalAlignment="Center" VerticalAlignment="Center">
                        <TextBlock Text="变比手动模式：" Width="120" Style="{StaticResource Label}" Margin="0,0,10,0"/>
                        <CheckBox Name="cbEnableRatioInputMode" IsChecked="False" Width="220"/>
                    </StackPanel>
                    <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Center" VerticalAlignment="Center">
                        <TextBlock Text="显示变比输入框：" Width="120" Style="{StaticResource Label}" Margin="0,0,10,0"/>
                        <CheckBox Name="cbShowRatioInputControls" IsChecked="False" Width="220"/>
                    </StackPanel>
                    <StackPanel Grid.Row="3" Orientation="Horizontal" HorizontalAlignment="Center" VerticalAlignment="Center">
                        <TextBlock Text="显示实时温度：" Width="120" Style="{StaticResource Label}" Margin="0,0,10,0"/>
                        <CheckBox Name="cbShowRealTimeTemperature" IsChecked="True" Width="220"/>
                    </StackPanel>
                    <StackPanel Grid.Row="4" Orientation="Horizontal" HorizontalAlignment="Center" VerticalAlignment="Center">
                        <TextBlock Text="显示折线图：" Width="120" Style="{StaticResource Label}" Margin="0,0,10,0"/>
                        <CheckBox Name="cbShowTemperatureChart" IsChecked="True" Width="220"/>
                    </StackPanel>
                </Grid>
           </TabItem>
           <TabItem Header="PLC设置" Visibility="Collapsed">
               <Grid Margin="20, 20, 20, 0" Height="300">
                   <Grid.RowDefinitions>
                       <RowDefinition Height="1*"/>
                       <RowDefinition Height="1*"/>
                       <RowDefinition Height="1*"/>
                       <RowDefinition Height="1*"/>
                   </Grid.RowDefinitions>
                   <StackPanel Grid.Row="0" Orientation="Horizontal" HorizontalAlignment="Center" VerticalAlignment="Center">
                       <TextBlock Text="PLC IP地址：" Width="120" Style="{StaticResource Label}" Margin="0,0,10,0"/>
                       <TextBox Name="tbPLCAlertIP" Width="220"/>
                   </StackPanel>
                   <StackPanel Grid.Row="1" Orientation="Horizontal" HorizontalAlignment="Center" VerticalAlignment="Center">
                       <TextBlock Text="CPU Rack：" Width="120" Style="{StaticResource Label}" Margin="0,0,10,0"/>
                       <TextBox Name="tbPLCAlertRack" Width="220"/>
                   </StackPanel>
                   <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Center" VerticalAlignment="Center">
                       <TextBlock Text="CPU Slot：" Width="120" Style="{StaticResource Label}" Margin="0,0,10,0"/>
                       <TextBox Name="tbPLCAlertSlot" Width="220"/>
                   </StackPanel>
                   <StackPanel Grid.Row="3" Orientation="Horizontal" HorizontalAlignment="Center" VerticalAlignment="Center">
                       <TextBlock Text="DB地址：" Width="120" Style="{StaticResource Label}" Margin="0,0,10,0"/>
                       <TextBox Name="tbPLCAlertAddress" Width="220"/>
                   </StackPanel>
               </Grid>
           </TabItem>
           <TabItem Header="数据库迁移" Height="40" Visibility="Collapsed">
                <Grid Margin="20, 20, 20, 0">
                    <StackPanel Orientation="Vertical" HorizontalAlignment="Center" VerticalAlignment="Center">
                        <TextBlock Text="为 commonTempRiseTestRecord 表增加 200kW 水冷需要的四个字段：&#10;OutletAirTemperature5 ~ OutletAirTemperature8" 
                                   FontSize="16" TextAlignment="Center" Margin="0,0,0,20"/>
                        <Button Name="btMigrateDB" Content="一键迁移数据库" Style="{StaticResource ButtonPrimary}" 
                                FontSize="18" Height="50" Width="220" Click="btMigrateDB_Click"/>
                    </StackPanel>
                </Grid>
            </TabItem>
        </TabControl>
        <StackPanel Grid.Row="1" Height="80" Orientation="Horizontal" HorizontalAlignment="Center" VerticalAlignment="Center">
            <Button Name="btComfirm" Style="{StaticResource ButtonPrimary}" FontSize="16" FontWeight="Bold" Content="确认" Height="40" Width="170" Margin="0,0,10,0" Click="btComfirm_Click"/>
            <Button Name="btCancel" Style="{StaticResource ButtonDanger}" FontSize="16" FontWeight="Bold" Content="取消" Height="40" Width="170" Margin="0,0,0,0" Click="btCancel_Click"/>
        </StackPanel>
    </Grid>
</Window>
