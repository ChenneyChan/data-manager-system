                    <TextBlock Text="高压绕组" HorizontalAlignment="Center" FontSize="18" Margin="0, 0, 0, 10" FontWeight="Bold"/>
                    <StackPanel Orientation="Horizontal">
                        <Views:ToggleButton ButtonContent="A - B" Width="{StaticResource tbContentWidth}" Height="{StaticResource tbContentHeight}" CheckedChange="HighVoltageSelectedTappingChange" x:Name="tbAB"/>
                        <Views:ToggleButton ButtonContent="A - 0" Width="{StaticResource tbContentWidth}" Height="{StaticResource tbContentHeight}" CheckedChange="HighVoltageSelectedTappingChange" x:Name="tbAO"/>
                    </StackPanel>
                    <StackPanel Orientation="Horizontal">
                        <Views:ToggleButton ButtonContent="B - C" Width="{StaticResource tbContentWidth}" Height="{StaticResource tbContentHeight}" CheckedChange="HighVoltageSelectedTappingChange" x:Name="tbBC"/>
                        <Views:ToggleButton ButtonContent="B - 0" Width="{StaticResource tbContentWidth}" Height="{StaticResource tbContentHeight}" CheckedChange="HighVoltageSelectedTappingChange" x:Name="tbBO"/>
                    </StackPanel>
                    <StackPanel Orientation="Horizontal">
