                        <Views:ToggleButton ButtonContent="3分接"   Width="{StaticResource tbContentWidth}" Height="{StaticResource tbContentHeight}" CheckedChange="TappingSelectedTappingChange" x:Name="tbTapping3"/>
                        <Views:ToggleButton ButtonContent="4分接"   Width="{StaticResource tbContentWidth}" Height="{StaticResource tbContentHeight}" CheckedChange="TappingSelectedTappingChange" x:Name="tbTapping4"/>
                        <Views:ToggleButton ButtonContent="5分接"   Width="{StaticResource tbContentWidth}" Height="{StaticResource tbContentHeight}" CheckedChange="TappingSelectedTappingChange" x:Name="tbTapping5"/>
