                    </WrapPanel>
                </StackPanel>
            </ScrollViewer>
            <!--列表分组-->
            <Grid Visibility="Visible" Grid.Row="0" Grid.Column="0" Name="dataGridPanel">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>
