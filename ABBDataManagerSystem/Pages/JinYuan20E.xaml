                    </StackPanel>
                    <hc:Divider Margin="5"/>
                    <TextBlock Text="低压绕组" HorizontalAlignment="Center" FontSize="18" Margin="0, 0, 0, 10" FontWeight="Bold"/>
                    <StackPanel Orientation="Horizontal">
                        <Views:ToggleButton ButtonContent="a - b" Width="{StaticResource tbContentWidth}" Height="{StaticResource tbContentHeight}" CheckedChange="LowVoltageSelectedTappingChange" x:Name="tbab"/>
                        <Views:ToggleButton ButtonContent="a - o" Width="{StaticResource tbContentWidth}" Height="{StaticResource tbContentHeight}" CheckedChange="LowVoltageSelectedTappingChange" x:Name="tbao"/>
