             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:ABBDataManagerSystem.Pages" 
             xmlns:sys="clr-namespace:System;assembly=mscorlib"
             xmlns:hc="https://handyorg.github.io/handycontrol"
             mc:Ignorable="d" Background="#FFDDDDDD" Loaded="UserControl_Loaded" Unloaded="UserControl_Unloaded" d:DesignHeight="895.5" d:DesignWidth="1661.356" MinWidth="1560" MinHeight="900">
    <UserControl.Resources>
        <sys:Double x:Key="tableCellFontSize">18</sys:Double>
        <sys:Double x:Key="tableHeaderFontSize">22</sys:Double>
        <sys:Double x:Key="tbContentHeight">40</sys:Double>
        <sys:Double x:Key="tbContentWidth">100</sys:Double>
        <Style TargetType="TextBlock" BasedOn="{StaticResource {x:Type TextBlock}}">
            <Setter Property="FontSize" Value="16"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
        </Style>
        <Style TargetType="Button" BasedOn="{StaticResource ButtonInfo}">
            <Setter Property="FontSize" Value="16"/>
            <Setter Property="Width" Value="120"/>
            <Setter Property="Height" Value="36"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
            <Setter Property="Background" Value="Aquamarine"/>
            <Setter Property="Foreground" Value="Black"/>
            <!--<Setter Property="FontWeight" Value="Bold"/>-->
        </Style>
        <Style TargetType="Views:ToggleButton">
