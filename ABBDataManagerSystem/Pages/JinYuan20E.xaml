                        <Views:ToggleButton ButtonContent="b - o" Width="{StaticResource tbContentWidth}" Height="{StaticResource tbContentHeight}" CheckedChange="LowVoltageSelectedTappingChange" x:Name="tbbo"/>
                    </StackPanel>
                    <StackPanel Orientation="Horizontal">
                        <Views:ToggleButton ButtonContent="c - a" Width="{StaticResource tbContentWidth}" Height="{StaticResource tbContentHeight}" CheckedChange="LowVoltageSelectedTappingChange" x:Name="tbca"/>
                        <Views:ToggleButton ButtonContent="c - o" Width="{StaticResource tbContentWidth}" Height="{StaticResource tbContentHeight}" CheckedChange="LowVoltageSelectedTappingChange" x:Name="tbco"/>
                    </StackPanel>
                    <TextBlock Text="低压" HorizontalAlignment="Center" FontSize="18" Margin="0, 0, 0, 10" FontWeight="Bold"/>
