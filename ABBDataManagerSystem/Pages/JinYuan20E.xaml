            </StackPanel>
            <StackPanel HorizontalAlignment="Left" Orientation="Horizontal" VerticalAlignment="Top">
                <TextBlock Width="60" Text="波特率" VerticalAlignment="Center" Margin="20, 0"/>
                <hc:ComboBox Width="120"  VerticalAlignment="Center" Name="cbBoundRate" SelectedIndex="1">
                    <ComboBoxItem Content="4800"/>
                    <ComboBoxItem Content="9600"/>
                    <ComboBoxItem Content="12800"/>
                </hc:ComboBox>
            </StackPanel>

            <hc:ButtonGroup Visibility="Collapsed" Margin="10,0,0,0" Orientation="Horizontal" Style="{StaticResource ButtonGroupSolid}">
                <RadioButton Content="高压通道" FontSize="18"/>
                <RadioButton Content="低压通道" FontSize="18" IsChecked="False"/>
            </hc:ButtonGroup>

            <StackPanel HorizontalAlignment="Left" Orientation="Horizontal" VerticalAlignment="Top" Margin="10,0" Name="panelConfig">
                <hc:ComboBox Width="140" Margin="5,0" Name="cb20ECurrents" hc:InfoElement.Title="电压" hc:InfoElement.TitlePlacement="left" SelectionChanged="cb20E_ComboBox_ConfigChanges"/>
                <hc:ComboBox Width="160" Margin="5,0" Name="cb20EPatterns" hc:InfoElement.Title="模式" hc:InfoElement.TitlePlacement="left" SelectionChanged="cb20E_ComboBox_ConfigChanges"/>
            </StackPanel>
        </StackPanel>

