                        <ComboBoxItem Content="负载"/>
                    </hc:ComboBox>
                    <TextBlock Text="状态" Width="32" Margin="10,0" VerticalAlignment="Center"/>
                    <hc:ComboBox Width="80" VerticalAlignment="Center" Name="cbTestStatus">
                        <ComboBoxItem Content="本体" IsSelected="True"/>
                        <ComboBoxItem Content="罩壳"/>
                    </hc:ComboBox>
                    <TextBlock Text="次数" Width="32" Margin="10,0" VerticalAlignment="Center"/>
                    <hc:ComboBox Width="80" VerticalAlignment="Center" Name="cbTestCount">
                        <ComboBoxItem Content="1" IsSelected="True"/>
