                    </hc:ComboBox>
                    <Button Content="上传数据" Name="btUpdateTempRiseRecords" Margin="10, 0" Click="btUpdateTempRiseRecords_Click"/>
                </StackPanel>
                <DataGrid Grid.Row="1" Name="lvUsers" AutoGenerateColumns="False" ItemsSource="{Binding Items}" FontSize="18" CanUserAddRows="False" CanUserDeleteRows="False" CanUserSortColumns="False">
                    <DataGrid.Columns>
                        <DataGridTextColumn Header="次数" Width="80"  Binding="{Binding SortIndex}"  IsReadOnly="True"/>
                        <DataGridTextColumn Header="采集时间" Width="120" Binding="{Binding CurrentTime}"  IsReadOnly="True"/>
                        <DataGridTextColumn Header="通道1电流(A)" Width="130" Binding="{Binding CurrentHV, StringFormat='F5'}"    IsReadOnly="True"/>
                        <DataGridTextColumn Header="通道1电阻(Ω)" Width="134" Binding="{Binding ResistanceHV, StringFormat='F5'}" IsReadOnly="True"/>
                        <DataGridTextColumn Header="通道2电流(A)" Width="130" Binding="{Binding CurrentLV, StringFormat='F5'}"    IsReadOnly="True"/>
                        <DataGridTextColumn Header="通道2电阻(Ω)" Width="134" Binding="{Binding ResistanceLV, StringFormat='F5'}" IsReadOnly="True"/>
                    </DataGrid.Columns>
                </DataGrid>
            </Grid>

