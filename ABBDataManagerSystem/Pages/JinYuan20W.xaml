<UserControl x:Class="ABBDataManagerSystem.Pages.JinYuan20W"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:ABBDataManagerSystem.Pages"
             mc:Ignorable="d" 
             d:DesignHeight="450" d:DesignWidth="800" Loaded="UserControl_Loaded">
    <Grid>
        <StackPanel HorizontalAlignment="Left" Margin="227,82,0,0" Orientation="Horizontal" VerticalAlignment="Top">
            <TextBlock TextWrapping="Wrap" Text="波特率" VerticalAlignment="Center" Margin="10, 0"/>

            <ComboBox Width="120"  VerticalAlignment="Center" Name="cbBoundRate" SelectedIndex="1">
                <ComboBoxItem Content="4800"/>
                <ComboBoxItem Content="9600"/>
                <ComboBoxItem Content="12800"/>
            </ComboBox>
        </StackPanel>
        <StackPanel HorizontalAlignment="Left" Orientation="Horizontal" VerticalAlignment="Top" Margin="27,84,0,0">
            <TextBlock TextWrapping="Wrap" Text="串口" VerticalAlignment="Center" Width="40"/>
            <ComboBox Width="120" x:Name="cbSerialPort"/>

        </StackPanel>
        <Button Content="开始采集" HorizontalAlignment="Left" Margin="28,130,0,0" VerticalAlignment="Top" RenderTransformOrigin="-0.934,-0.163" Height="29" Width="80"/>
        <Button Content="停止采集" HorizontalAlignment="Left" Margin="130,130,0,0" VerticalAlignment="Top" RenderTransformOrigin="-0.934,-0.163" Height="29" Width="80"/>
        <TextBlock HorizontalAlignment="Left" Margin="27,21,0,0" TextWrapping="Wrap" VerticalAlignment="Top" Text="金源20W测量仪" FontSize="18" FontWeight="Bold"/>
        <StackPanel HorizontalAlignment="Left" Orientation="Horizontal" VerticalAlignment="Top" Margin="438,90,0,0">
            <CheckBox Content="通道一" />
            <Viewbox Width="10"/>
            <CheckBox Content="通道二" />

        </StackPanel>
        <StackPanel HorizontalAlignment="Left" Margin="272,138,0,0" Orientation="Horizontal" VerticalAlignment="Top">
            <TextBlock TextWrapping="Wrap" Text="测试类型" VerticalAlignment="Center"/>
            <Viewbox Width="10"/>
            <ComboBox Width="120" x:Name="cbTestType" SelectedIndex="0">
                <ComboBoxItem Content="常规测试"/>
                <ComboBoxItem Content="温升测试-10秒"/>
                <ComboBoxItem Content="温升测试-30秒"/>
                <ComboBoxItem Content="温升测试-60秒"/>
            </ComboBox>

        </StackPanel>

    </Grid>
</UserControl>
