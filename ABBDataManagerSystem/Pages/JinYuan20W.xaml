<UserControl xmlns:controls="https://handyorg.github.io/handycontrol"  x:Class="ABBDataManagerSystem.Pages.JinYuan20W"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:ABBDataManagerSystem.Pages"
             mc:Ignorable="d" Loaded="UserControl_Loaded" Height="462" Width="872">
    <UserControl.Resources>
        <Style TargetType="{x:Type GridViewColumnHeader}" BasedOn="{StaticResource {x:Type GridViewColumnHeader}}">
            <Setter Property="HorizontalContentAlignment" Value="Center" />
            <!--<Setter Property="Background" Value="#FF347071"/>-->
            <!--<Setter Property="Foreground" Value="White"/>-->
            <Setter Property="FontSize" Value="24"/>
        </Style>
        <Style TargetType="TextBlock" BasedOn="{StaticResource {x:Type TextBlock}}">
            <Setter Property="FontSize" Value="18"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
        </Style>
        <Style TargetType="Button" BasedOn="{StaticResource {x:Type Button}}">
            <Setter Property="FontSize" Value="18"/>
            <Setter Property="Width" Value="120"/>
            <Setter Property="Height" Value="40"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
        </Style>
        <Style TargetType="CheckBox" BasedOn="{StaticResource {x:Type CheckBox}}">
            <Setter Property="FontSize" Value="18"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
        </Style>
        <Style TargetType="ComboBox" BasedOn="{StaticResource {x:Type ComboBox}}">
            <Setter Property="FontSize" Value="18"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
        </Style>
    </UserControl.Resources>
    <Grid Margin="30,20,30,20">
        <Grid.ColumnDefinitions>

        </Grid.ColumnDefinitions>
        <Grid.RowDefinitions>
            <RowDefinition Height="60"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="120"/>
            <RowDefinition Height="1*"/>
        </Grid.RowDefinitions>
        <StackPanel Grid.Row="0">
            <TextBlock HorizontalAlignment="Left" Margin="0,10" TextAlignment="Center" TextWrapping="Wrap" Text="金源20W测量仪" FontSize="24" FontWeight="Bold"/>
        </StackPanel>
        <StackPanel Orientation="Horizontal" Grid.Row="1" Margin="0, 10">
            <StackPanel HorizontalAlignment="Left" Orientation="Horizontal" VerticalAlignment="Top">
                <TextBlock TextWrapping="Wrap" Text="串口" VerticalAlignment="Center" Width="40" Margin="0,0,20,0"/>
                <ComboBox Width="120" Name="cbSerialPort"/>
            </StackPanel>
            <StackPanel HorizontalAlignment="Left" Orientation="Horizontal" VerticalAlignment="Top">
                <TextBlock Width="60" Text="波特率" VerticalAlignment="Center" Margin="20, 0"/>
                <ComboBox Width="120"  VerticalAlignment="Center" Name="cbBoundRate" SelectedIndex="1">
                    <ComboBoxItem Content="4800"/>
                    <ComboBoxItem Content="9600"/>
                    <ComboBoxItem Content="12800"/>
                </ComboBox>
            </StackPanel>

            <StackPanel HorizontalAlignment="Left" Orientation="Horizontal" VerticalAlignment="Top" Margin="10,0">
                <CheckBox Content="高压侧" VerticalAlignment="Center"/>
                <Viewbox Width="10"/>
                <ComboBox Width="100" Name="cbHVCurrents"/>
                <Viewbox Width="10"/>
                <CheckBox Content="低压侧" VerticalAlignment="Center"/>
                <Viewbox Width="10"/>
                <ComboBox Width="100" Name="cbLVCurrents"/>
            </StackPanel>
        </StackPanel>

        <StackPanel Orientation="Horizontal" Grid.Row="2" Margin="10, 10">
            <Button Content="开始采集" HorizontalAlignment="Left" Margin="0,0,10,0" VerticalAlignment="Top" />
            <Button Content="停止采集" HorizontalAlignment="Left" Margin="0,0,20,0" VerticalAlignment="Top" />
            <StackPanel HorizontalAlignment="Left" Margin="0,0" Orientation="Horizontal" VerticalAlignment="Center">
                <TextBlock TextWrapping="Wrap" Text="测试类型" VerticalAlignment="Center" Margin="20,0"/>
                <ComboBox Width="120" Name="cbTestType" SelectedIndex="0">
                    <ComboBoxItem Content="常规测试"/>
                    <ComboBoxItem Content="温升测试-10秒"/>
                    <ComboBoxItem Content="温升测试-30秒"/>
                    <ComboBoxItem Content="温升测试-60秒"/>
                </ComboBox>
            </StackPanel>
        </StackPanel>
        <Grid Grid.Row="3" Margin="10">
            <Grid.ColumnDefinitions>
                <ColumnDefinition/>
                <ColumnDefinition/>
            </Grid.ColumnDefinitions>
            <StackPanel Grid.Column="0" Orientation="Vertical" HorizontalAlignment="Center">
                <TextBlock Text="高压侧" FontSize="24" Style="{StaticResource TextBlockLargeBold}"/>
            </StackPanel>
            <StackPanel Grid.Column="1" Orientation="Vertical" HorizontalAlignment="Center">
                <TextBlock Text="低压侧" FontSize="24" Style="{StaticResource TextBlockLargeBold}"/>
            </StackPanel>
        </Grid>
        <Grid Grid.Row="4">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="1*"/>
            </Grid.ColumnDefinitions>
            <!--<DataGrid  Grid.Column="0" Name="resultDataGrid"/>-->
            <!--列表分组-->
            <ListView Name="lvUsers">
                <ListView.View>
                    <GridView>
                        <GridViewColumn Header="次数" Width="80" DisplayMemberBinding="{Binding SortIndex}" />
                        <GridViewColumn Header="电流" Width="120" DisplayMemberBinding="{Binding Current}" />
                        <GridViewColumn Header="电阻" Width="120" DisplayMemberBinding="{Binding Resistance}" />
                    </GridView>
                </ListView.View>
                <ListView.GroupStyle>
                    <GroupStyle>
                        <GroupStyle.HeaderTemplate>
                            <DataTemplate>
                                <TextBlock FontWeight="Bold" FontSize="18" Text="{Binding SortIndex}"/>
                            </DataTemplate>
                        </GroupStyle.HeaderTemplate>
                    </GroupStyle>
                </ListView.GroupStyle>
            </ListView>
            <StackPanel Orientation="Vertical" Grid.Column="1">
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Left">
                    <Button Content="New Item" Name="btAddRecord" Click="btAddRecord_Click" controls:BorderElement.CornerRadius="15" Height="40"/>
                    <Button Content="Delte Item" Name="btDeleteRecord" Click="btDeleteRecord_Click" controls:BorderElement.CornerRadius="15" Height="40"/>

                    <!--内部Item样式为ButtonGroup控件自动附加-默认为水平方向item样式-->
                    <controls:ButtonGroup Margin="0,32,0,0">
                        <RadioButton Content="RadioButton" IsChecked="True"/>
                        <RadioButton Content="RadioButton"/>
                        <RadioButton IsEnabled="False" Content="RadioButton"/>
                        <RadioButton Content="RadioButton"/>
                    </controls:ButtonGroup>
                    <controls:ButtonGroup Margin="0,16,0,0" Style="{StaticResource ButtonGroupSolid}">
                        <RadioButton Content="RadioButton"/>
                        <RadioButton Content="RadioButton"/>
                        <RadioButton IsEnabled="False" Content="RadioButton"/>
                        <RadioButton Content="RadioButton" IsChecked="True"/>
                    </controls:ButtonGroup>
                </StackPanel>
                <!-- ListView控件 -->
                <ListView Name="myListView"
                  ItemsSource="{Binding Items}"
                  SelectionMode="Multiple">
                    <!-- 列定义 -->
                    <ListView.View>
                        <GridView>
                            <GridViewColumn Header="名称"
                                    DisplayMemberBinding="{Binding Name}"
                                    Width="120"/>
                            <GridViewColumn Header="描述"
                                    DisplayMemberBinding="{Binding Description}"
                                    Width="200"/>
                        </GridView>
                    </ListView.View>
                </ListView>
            </StackPanel>
        </Grid>
    </Grid>
</UserControl>
