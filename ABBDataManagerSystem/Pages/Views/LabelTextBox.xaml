<UserControl x:Class="ABBDataManagerSystem.Pages.Views.LabelTextBox"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:ABBDataManagerSystem.Pages.Views"
             mc:Ignorable="d" 
             d:DesignHeight="100" d:DesignWidth="800">
    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="Auto"/>
            <ColumnDefinition  Width="*"/>
        </Grid.ColumnDefinitions>
        <TextBlock Text="{Binding LabelText}"  VerticalAlignment="Center" Margin="0, 0, 5 ,0" FontSize="{Binding FontSize}"/>
        <TextBox Grid.Column="1" FontSize="{Binding FontSize}" Text="{Binding ContentText}"/>
    </Grid>
</UserControl>
