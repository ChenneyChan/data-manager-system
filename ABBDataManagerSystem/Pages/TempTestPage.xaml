<UserControl xmlns:oxy="http://oxyplot.org/wpf"  x:Class="ABBDataManagerSystem.Pages.TempTestPage"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:ABBDataManagerSystem.Pages"
             xmlns:hc="https://handyorg.github.io/handycontrol" 
             mc:Ignorable="d" 
             d:DesignHeight="1080" d:DesignWidth="1920" Loaded="UserControl_Loaded" Unloaded="UserControl_Unloaded" MinHeight="800" MinWidth="1200">
    <UserControl.Resources>
        <Style TargetType="RadioButton" BasedOn="{StaticResource {x:Type RadioButton}}">
            <Setter Property="FontSize" Value="18"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
        </Style>
        <Style TargetType="TextBlock" BasedOn="{StaticResource {x:Type TextBlock}}">
            <Setter Property="FontSize" Value="18"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
        </Style>
        <Style TargetType="Button" BasedOn="{StaticResource {x:Type Button}}">
            <Setter Property="FontSize" Value="18"/>
            <Setter Property="Width" Value="140"/>
            <Setter Property="Height" Value="40"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
        </Style>
        <Style TargetType="CheckBox" BasedOn="{StaticResource {x:Type CheckBox}}">
            <Setter Property="FontSize" Value="18"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
        </Style>
        <Style TargetType="hc:ComboBox" BasedOn="{StaticResource GlobalComboBoxStyle}">
            <Setter Property="FontSize" Value="18"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
        </Style>
        <Style TargetType="Button" x:Key="plotButton" BasedOn="{StaticResource {x:Type Button}}">
            <Setter Property="Height" Value="38"/>
            <Setter Property="Width" Value="120"/>
            <Setter Property="FontSize" Value="16"/>
        </Style>
        <Style TargetType="Button" x:Key="startbutton" BasedOn="{StaticResource {x:Type Button}}">
            <Setter Property="Height" Value="40"/>
            <Setter Property="Width" Value="120"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="BorderThickness" Value="1"/>
        </Style>
        <Style TargetType="hc:TextBox" BasedOn="{StaticResource GlobalTextBoxStyle}">
            
        </Style>
    </UserControl.Resources>
    <Grid Margin="30,20,30,20">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="1*"/>
        </Grid.RowDefinitions>
        <Grid Grid.Row="0" Grid.Column="0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="800"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>
            <StackPanel Orientation="Vertical" >
                <StackPanel Orientation="Horizontal">
                    <RadioButton Content="串口" VerticalAlignment="Center" Name="rbSerialPort"/>
                    <TextBlock Text="串口" Width="40" Margin="20,0" VerticalAlignment="Center"/>
                    <hc:ComboBox Width="120" VerticalAlignment="Center" Name="cbSerialPort"/>
                    <TextBlock Text="波特率" Width="60" Margin="20,0" VerticalAlignment="Center"/>
                    <hc:ComboBox Width="100" VerticalAlignment="Center" Name="cbSerialBoudRate"/>
                </StackPanel>
                <StackPanel Orientation="Horizontal" Margin="0, 20">
                    <RadioButton Content="网口" VerticalAlignment="Center" Name="rbEthernet"/>
                    <TextBlock Text="IP" Width="40" Margin="20,0" VerticalAlignment="Center"/>
                    <hc:TextBox Width="120" VerticalAlignment="Center" Name="tbEthernetIP"/>
                    <TextBlock Text="端口号" Width="60" Margin="20,0" VerticalAlignment="Center"/>
                    <hc:TextBox Width="100" VerticalAlignment="Center" Name="tbEthernetPort"/>
                    <!--<TextBlock Text="通道数" Width="60" Margin="20,0" VerticalAlignment="Center"/>
                    <hc:ComboBox Width="100" VerticalAlignment="Center" Name="cbSlotNums"/>-->
                    <TextBlock Text="采集周期" Width="80" Margin="20,0" VerticalAlignment="Center"/>
                    <hc:ComboBox Width="100" VerticalAlignment="Center" Name="cbInterval"/>
                </StackPanel>
                <StackPanel Orientation="Horizontal" Margin="0, 0, 0, 20">
                    <Button Name="btStart" Content="开始采集" Grid.Column="0" Grid.Row="0" Click="btStart_Click" Style="{StaticResource startbutton}" Background="DodgerBlue"/>
                    <!--<DockPanel Grid.Column="1" Grid.Row="0"></DockPanel>-->
                    <TextBlock Text="存储到CVS路径：" VerticalAlignment="Center" Margin="20,0"/>
                    <hc:TextBox Grid.Column="1" Grid.Row="0" HorizontalAlignment="Stretch" MinWidth="360" Name="tbSaveFilePath" IsReadOnly="True"/>
                </StackPanel>
            </StackPanel>

            <!--<TextBlock Text="通道选择" Width="80" Grid.Column="0" Margin="0, 0, 20,0"/>-->
            <StackPanel Grid.Column="1" >
                <hc:CheckComboBox MaxHeight="200" hc:InfoElement.ShowClearButton="True" FontSize="18"
                                        hc:InfoElement.TitlePlacement="Top" hc:InfoElement.Placeholder="选择监视通道" hc:InfoElement.Title="通道选择" 
                                        Name="mcbSelectedSlots" ShowSelectAllButton="True" ItemsSource="{Binding DataList}" Style="{StaticResource CheckComboBoxPlus}" 
                                        HorizontalAlignment="Stretch" SelectionChanged="mcbSelectedSlots_SelectionChanged" VerticalAlignment="Top"/>

            </StackPanel>
        </Grid>
        <WrapPanel Grid.Column="0" Grid.Row="1" Name="SlotWrapPanel" Background="#FFBDCDE6" Grid.ColumnSpan="2" Margin="0,10,0,0">
            <!--<local:ProductInfo Width="50" Height="50"/>-->
        </WrapPanel>
        <Grid Grid.Column="0" Grid.Row="2" Grid.ColumnSpan="2" Margin="0,5" Grid.RowSpan="3" >
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="1*"/>
                <ColumnDefinition Width="120"/>
            </Grid.ColumnDefinitions>
            <oxy:PlotView Grid.Row="0" Grid.Column="0" Name="plotView" Margin="5,5"/>
            <Grid Grid.Row="0" Grid.Column="1">
                <StackPanel Orientation="Vertical" Margin="0, 20">
                    <Button Style="{StaticResource plotButton}" Content="清空" Margin="0, 5" Name="btClearChart" Click="btClear_Click"/>
                    <Button Style="{StaticResource plotButton}" Content="恢复" Margin="0, 5" Name="btResetChartAxias" Click="btResteAxis_Click"/>
                    <Button Style="{StaticResource plotButton}" Content="导出为图片" Margin="0, 5" Name="btExportChartPng" Click="btSaveToPng_Click"/>
                    <Button Style="{StaticResource plotButton}" Content="显隐题注" Margin="0, 5" Name="btResumeChart" Click="btToogleLegends_Click"/>
                    <Button Style="{StaticResource plotButton}" Content="隐藏所有线条" Margin="0, 5" Name="btHideAllLine" Click="tbHideAllLine_Click"/>
                    <Button Style="{StaticResource plotButton}" Content="恢复所有线条" Margin="0, 5" Name="btResumeAllLine" Click="btResumeLines_Click"/>
                </StackPanel>
            </Grid>
        </Grid>
    </Grid>
</UserControl>
