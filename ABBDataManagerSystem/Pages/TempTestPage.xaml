<UserControl xmlns:oxy="http://oxyplot.org/wpf"  x:Class="ABBDataManagerSystem.Pages.TempTestPage"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:ABBDataManagerSystem.Pages"
             mc:Ignorable="d" 
             d:DesignHeight="450" d:DesignWidth="800" Loaded="UserControl_Loaded" Unloaded="UserControl_Unloaded">
    <UserControl.Resources>
        <Style TargetType="Button" x:Key="plotButton">
            <Setter Property="Height" Value="30"/>
        </Style>
    </UserControl.Resources>
    <Grid Margin="20,20">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="671*"/>
            <ColumnDefinition Width="89*"/>
        </Grid.ColumnDefinitions>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="1*"/>
        </Grid.RowDefinitions>
        <StackPanel Orientation="Vertical" Grid.ColumnSpan="2">
            <StackPanel Orientation="Horizontal">
                <RadioButton Content="串口" VerticalAlignment="Center" Name="rbSerialPort"/>
                <TextBlock Text="串口" Width="30" Margin="10,0" VerticalAlignment="Center"/>
                <ComboBox Width="100" VerticalAlignment="Center" Name="cbSerialPort"/>
                <TextBlock Text="波特率" Width="40" Margin="10,0" VerticalAlignment="Center"/>
                <ComboBox Width="100" VerticalAlignment="Center" Name="cbSerialBoudRate"/>
            </StackPanel>
            <StackPanel Orientation="Horizontal" Margin="0, 10">
                <RadioButton Content="网口" VerticalAlignment="Center" Name="rbEthernet"/>
                <TextBlock Text="IP" Width="30" Margin="10,0" VerticalAlignment="Center"/>
                <TextBox Width="100" VerticalAlignment="Center" Name="tbEthernetIP"/>
                <TextBlock Text="端口号" Width="40" Margin="10,0" VerticalAlignment="Center"/>
                <TextBox Width="100" VerticalAlignment="Center" Name="tbEthernetPort"/>
                <TextBlock Text="通道数" Width="40" Margin="10,0" VerticalAlignment="Center"/>
                <ComboBox Width="100" VerticalAlignment="Center" Name="cbSlotNums"/>
                <TextBlock Text="采集周期" Width="50" Margin="10,0" VerticalAlignment="Center"/>
                <ComboBox Width="100" VerticalAlignment="Center" Name="cbInterval"/>
            </StackPanel>
            <StackPanel Orientation="Horizontal" Margin="0, 10">
                <Button Name="btStart" Content="开始采集" Width="100" Height="30" Grid.Column="0" Grid.Row="0" Click="btStart_Click"/>
                <!--<DockPanel Grid.Column="1" Grid.Row="0"></DockPanel>-->
                <TextBlock Text="存储到CVS路径：" VerticalAlignment="Center" Margin="10,0"/>
                <TextBox Grid.Column="1" Grid.Row="0" HorizontalAlignment="Stretch" MinWidth="200" Name="tbSaveFilePath" IsReadOnly="True"/>
            </StackPanel>
        </StackPanel>
        <WrapPanel Grid.Column="0" Grid.Row="1" Name="SlotWrapPanel" Background="#FFBDCDE6" Grid.ColumnSpan="2" Margin="0,5,0,0">
            <!--<local:ProductInfo Width="50" Height="50"/>-->
        </WrapPanel>
        <Grid Grid.Column="0" Grid.Row="2" Grid.ColumnSpan="2" Margin="0,5" Grid.RowSpan="3" >
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="1*"/>
                <ColumnDefinition Width="100"/>
            </Grid.ColumnDefinitions>
            <oxy:PlotView Grid.Row="0" Grid.Column="0" Name="plotView" Margin="5,5"/>
            <Grid Grid.Row="0" Grid.Column="1">
                <StackPanel Orientation="Vertical" Margin="0, 10">
                    <Button Style="{StaticResource plotButton}" Content="清空" Margin="0, 5" Name="btClearChart" Click="btClear_Click"/>
                    <Button Style="{StaticResource plotButton}" Content="恢复" Margin="0, 5" Name="btResetChartAxias" Click="btResteAxis_Click"/>
                    <Button Style="{StaticResource plotButton}" Content="导出为图片" Margin="0, 5" Name="btExportChartPng" Click="btSaveToPng_Click"/>
                    <Button Style="{StaticResource plotButton}" Content="显隐题注" Margin="0, 5" Name="btResumeChart" Click="btToogleLegends_Click"/>
                    <Button Style="{StaticResource plotButton}" Content="隐藏所有线条" Margin="0, 5" Name="btHideAllLine" Click="tbHideAllLine_Click"/>
                    <Button Style="{StaticResource plotButton}" Content="恢复所有线条" Margin="0, 5" Name="btResumeAllLine" Click="btResumeLines_Click"/>
                </StackPanel>
            </Grid>
        </Grid>
    </Grid>
</UserControl>
