<UserControl xmlns:oxy="http://oxyplot.org/wpf"  x:Class="ABBDataManagerSystem.Pages.TempTestPage"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:ABBDataManagerSystem.Pages"
             mc:Ignorable="d" 
             d:DesignHeight="450" d:DesignWidth="800">
    <UserControl.Resources>
        <Style TargetType="Button" x:Key="plotButton">
            <Setter Property="Height" Value="30"/>
        </Style>
    </UserControl.Resources>
    <Grid Margin="20,20">
        <Grid.ColumnDefinitions>
            <ColumnDefinition/>
        </Grid.ColumnDefinitions>
            <Grid.RowDefinitions>
            <RowDefinition Height="120"/>
            <RowDefinition Height="1*"/>
            <RowDefinition Height="20"/>
        </Grid.RowDefinitions>
        <StackPanel Orientation="Vertical">
            <StackPanel Orientation="Horizontal">
                <RadioButton Content="串口" VerticalAlignment="Center" Name="rbSerialPort"/>
                <TextBlock Text="串口" Margin="10,0" VerticalAlignment="Center"/>
                <ComboBox Width="100" VerticalAlignment="Center" Name="cbSerialPort"/>
                <TextBlock Text="速率" Margin="10,0" VerticalAlignment="Center"/>
                <ComboBox Width="100" VerticalAlignment="Center" Name="cbSerialBaudRate"/>
            </StackPanel>
            <StackPanel Orientation="Horizontal" Margin="0, 10">
                <RadioButton Content="网口" VerticalAlignment="Center" Name="rbEthernet"/>
                <TextBlock Text="IP" Margin="10,0" VerticalAlignment="Center"/>
                <TextBox Width="100" VerticalAlignment="Center" Name="tbEthernetIP"/>
                <TextBlock Text="端口" Margin="10,0" VerticalAlignment="Center"/>
                <ComboBox Width="100" VerticalAlignment="Center" Name="cbEthernetPort"/>
            </StackPanel>
            <StackPanel Orientation="Horizontal" Margin="0, 10">
                <Button Name="btStart" Content="开始采集" Width="100" Height="40" Click="btStart_Click"/>
            </StackPanel>
        </StackPanel>
        <Grid Grid.Row="1" Grid.Column="0" >
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="1*"/>
                <ColumnDefinition Width="100"/>
            </Grid.ColumnDefinitions>
            <oxy:PlotView Grid.Row="0" Grid.Column="0" Name="plotView" Margin="5,5"/>
            <Grid Grid.Row="0" Grid.Column="1">
                <StackPanel Orientation="Vertical">
                    <Button Style="{StaticResource plotButton}" Content="清空" Margin="0, 5"/>
                    <Button Style="{StaticResource plotButton}" Content="恢复" Margin="0, 5"/>
                    <Button Style="{StaticResource plotButton}" Content="导出" Margin="0, 5"/>
                    <Button Style="{StaticResource plotButton}" Content="还原" Margin="0, 5"/>
                </StackPanel>
            </Grid>
        </Grid>
    </Grid>
</UserControl>
