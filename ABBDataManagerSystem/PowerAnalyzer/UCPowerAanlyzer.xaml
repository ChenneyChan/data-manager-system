<UserControl x:Class="ABBDataManagerSystem.PowerAnalyzer.UCPowerAanlyzer"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:ABBDataManagerSystem.PowerAnalyzer"
             mc:Ignorable="d" 
             d:DesignHeight="450" d:DesignWidth="800" Loaded="UserControl_Loaded" Unloaded="UserControl_Unloaded">
    <Grid Margin="20,20">
        <Grid.ColumnDefinitions>
            <ColumnDefinition/>
            <ColumnDefinition/>
        </Grid.ColumnDefinitions>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition/>
            <RowDefinition/>
        </Grid.RowDefinitions>
        <StackPanel Grid.Row="0" Orientation="Horizontal">
            <TextBlock HorizontalAlignment="Left" TextWrapping="Wrap" Text="设备型号" VerticalAlignment="Center"/>
            <TextBox HorizontalAlignment="Left" TextWrapping="Wrap" Text="TextBox" VerticalAlignment="Center" Width="120" Name="tbModelType"/>
            <RadioButton Name="ASCIIOption" Content="ASCII" VerticalAlignment="Center"/>
            <RadioButton Name="BINARYOption" Content="BINARY" VerticalAlignment="Center"/>
        </StackPanel>
        <StackPanel Grid.Row="1" Orientation="Horizontal">
            <TextBlock HorizontalAlignment="Left" TextWrapping="Wrap" Text="电压档位" VerticalAlignment="Center" RenderTransformOrigin="0.521,2.493"/>
            <ComboBox HorizontalAlignment="Left"  VerticalAlignment="Center" Width="120" Name="cbVoltageRange"/>
            <TextBlock HorizontalAlignment="Left" TextWrapping="Wrap" Text="元素数量" VerticalAlignment="Center" RenderTransformOrigin="0.521,2.493"/>
            <ComboBox HorizontalAlignment="Left"  VerticalAlignment="Center" Width="120" Name="ItemNumberCombo"/>
        </StackPanel>
        <StackPanel Grid.Row="2" Orientation="Horizontal">
            <TextBlock HorizontalAlignment="Left" TextWrapping="Wrap" Text="电流档位" VerticalAlignment="Center" RenderTransformOrigin="0.521,2.493"/>
            <ComboBox HorizontalAlignment="Left"  VerticalAlignment="Center" Width="120" Name="cbCurrentRange"/>
            <Button Name="btRangeSet" Content="设置"/>
        </StackPanel>
        <StackPanel Grid.Row="0" Grid.Column="1" Orientation="Horizontal">
            <TextBlock HorizontalAlignment="Left" TextWrapping="Wrap" Text="刷新频率" VerticalAlignment="Center" RenderTransformOrigin="0.521,2.493"/>
            <ComboBox HorizontalAlignment="Left"  VerticalAlignment="Center" Width="120" Name="cbUpdateRate"/>
            <Button Content="设置" Width="40" Name="btSetUpdateRate"/>
        </StackPanel>
        <StackPanel Grid.Row="1" Grid.Column="1" Orientation="Horizontal">
            <Button Content="获取一次" Width="80" Name="btRequestSingle" HorizontalAlignment="Left"/>
            <Button Content="持续获取" Width="80" Name="btRequestContinue"/>
            <Button Content="持续获取（定时器）" Width="140" Name="btRequestTimer" HorizontalAlignment="Right"/>
        </StackPanel>
        <StackPanel Orientation="Horizontal" Grid.Row="2" Grid.Column="1">
            <TextBox IsReadOnly="True" Name="ErrInfoText" HorizontalAlignment="Stretch" MinWidth="200"/>
        </StackPanel>
        <DataGrid Grid.Row="3" Grid.ColumnSpan="2" Grid.RowSpan="2" Name="dataGrid"/>
    </Grid>
</UserControl>
